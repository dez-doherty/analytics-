{
  "manifest_version": 3,
  "name": "Analytics+",
  "version": "4.0",
  "description": "Adds an interactive dashboard with a heatmap, column chart, line chart and radial chart to your attendance page",
  "permissions": ["storage"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://aston.seats.cloud/*"],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ],

  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
